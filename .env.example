# ============================================
# DATABASE CONNECTION (SUPABASE)
# ============================================
# Replace with your Supabase connection string
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres"

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# Generate a secret key with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# GST CONFIGURATION FOR SKYPRINT
# ============================================
GSTIN="27SKYPRINT1234F1Z5"
COMPANY_NAME="Skyprint"
COMPANY_STATE="Maharashtra"

# ============================================
# OPTIONAL: FILE STORAGE (AWS S3)
# ============================================
# Uncomment and configure if you need file upload functionality
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET="skyprint-documents"

# ============================================
# OPTIONAL: EMAIL SERVICE
# ============================================
# Uncomment and configure for sending invoices/notifications via email
# EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
# EMAIL_FROM="noreply@skyprint.com"

# ============================================
# OPTIONAL: PAYMENT GATEWAY
# ============================================
# Uncomment and configure if integrating payment processing
# PAYMENT_GATEWAY_KEY="your-payment-gateway-key"
# PAYMENT_GATEWAY_SECRET="your-payment-gateway-secret"
